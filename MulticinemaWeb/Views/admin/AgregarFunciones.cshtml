@model MulticinemaWeb.Models.Funcione

@{
    ViewData["Title"] = "Crear Función";
}

<div class="container mt-4">
    <div class="card shadow" style="max-width: 600px; margin: auto;">
        <div class="card-header bg-success text-white">
            <h3 class="mb-0">➕ Nueva Función</h3>
        </div>
        <div class="card-body">
            <form asp-action="AgregarFunciones" method="post">

                <div class="mb-3">
                    <label class="form-label fw-bold">Película</label>
                    <select asp-for="IdPelicula" class="form-select" required>
                        <option value="">-- Seleccione una Película --</option>
                        @foreach (var p in ViewBag.Peliculas)
                        {
                            <option value="@p.IdPelicula">@p.Titulo</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Sala</label>
                    <select asp-for="IdSala" class="form-select" required>
                        <option value="">-- Seleccione una Sala --</option>
                        @foreach (var s in ViewBag.Salas)
                        {
                            <option value="@s.IdSala">@s.NombreSala (Capacidad: @s.CapacidadTotal)</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Fecha y Hora de Inicio</label>
                    <input asp-for="FechaHoraInicio" class="form-control" type="datetime-local" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Precio del Boleto ($)</label>
                    <input asp-for="Precio" class="form-control" type="number" step="0.01" placeholder="0.00" required />
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-success btn-lg">Guardar Función</button>
                    <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>