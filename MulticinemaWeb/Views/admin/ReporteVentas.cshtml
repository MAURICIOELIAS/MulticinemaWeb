@model IEnumerable<MulticinemaWeb.Models.Boleto>
@{
    ViewData["Title"] = "Reporte de Ventas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>💰 Reporte de Ventas: @ViewBag.Mes</h2>
        <div class="card bg-success text-white p-2">
            <h5 class="m-0">Total Ingresos: @ViewBag.TotalIngresos?.ToString("C")</h5>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No se han registrado ventas en este mes.
        </div>
    }
    else
    {
        <table class="table table-striped table-hover table-bordered shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Fecha</th>
                    <th>Película</th>
                    <th>Sala</th>
                    <th>Cliente</th>
                    <th>Asiento</th>
                    <th>Pagado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var venta in Model)
                {
                    <tr>
                        <td>@venta.FechaCompra?.ToString("dd/MM/yyyy HH:mm")</td>

                        <td>@venta.IdFuncionNavigation?.IdPeliculaNavigation?.Titulo</td>

                        <td>@venta.IdFuncionNavigation?.IdSalaNavigation?.NombreSala</td>

                        <td>@venta.IdUsuarioNavigation?.NombreCompleto</td>

                        <td class="text-center fw-bold">@venta.AsientoCodigo</td>

                        <td class="fw-bold text-success">@venta.PrecioPagado.ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-3">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">⬅ Volver al Panel</a>
    </div>
</div>