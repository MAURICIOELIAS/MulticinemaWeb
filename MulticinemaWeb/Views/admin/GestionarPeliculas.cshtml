@model IEnumerable<MulticinemaWeb.Models.Pelicula>

@{
    ViewData["Title"] = "Gestionar Películas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>🎬 Catálogo de Películas</h2>
        <a asp-action="CrearPelicula" class="btn btn-success">
            + Nueva Película
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            No hay películas registradas. ¡Agrega la primera!
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover shadow-sm bg-white">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Título</th>
                    <th>Duración</th>
                    <th>Clasificación</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.IdPelicula</td>
                        <td class="fw-bold">@item.Titulo</td>
                        <td>@item.DuracionMinutos min</td>
                        <td>
                            <span class="badge bg-secondary">@item.Clasificacion</span>
                        </td>
                        <td>
                            @if (item.Estado == "Activo")
                            {
                                <span class="text-success fw-bold">Disponible</span>
                            }
                            else
                            {
                                <span class="text-muted">@item.Estado</span>
                            }
                        </td>
                        <td>
                            <a asp-action="EditarPelicula" asp-route-id="@item.IdPelicula" class="btn btn-sm btn-primary">
                                ✏️ Editar
                            </a>

                            <a asp-action="EliminarPelicula" asp-route-id="@item.IdPelicula" class="btn btn-sm btn-danger"
                               onclick="return confirm('¿Estás seguro de eliminar la película: @item.Titulo?');">
                                🗑️ Borrar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-3">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">⬅ Volver al Panel</a>
    </div>
</div>