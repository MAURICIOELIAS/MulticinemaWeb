@model List<MulticinemaWeb.Models.Boleto>

@{
    ViewData["Title"] = "Compra Exitosa";
}

<style>
    /* ---animacion */
    .checkmark-wrapper {
        display: flex;
        justify-content: center;
        margin-bottom: 20px;
    }

    .checkmark__circle {
        stroke-dasharray: 166;
        stroke-dashoffset: 166;
        stroke-width: 2;
        stroke-miterlimit: 10;
        stroke: #28a745; /* color verde */
        fill: none;
        animation: stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
    }

    .checkmark {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: block;
        stroke-width: 2;
        stroke: #fff;
        stroke-miterlimit: 10;
        margin: 10% auto;
        box-shadow: inset 0px 0px 0px #28a745;
        animation: fill .4s ease-in-out .4s forwards, scale .3s ease-in-out .9s both;
    }

    .checkmark__check {
        transform-origin: 50% 50%;
        stroke-dasharray: 48;
        stroke-dashoffset: 48;
        animation: stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.8s forwards;
    }

    @@keyframes stroke {
        100%

    {
        stroke-dashoffset: 0;
    }

    }

    @@keyframes scale {
        0%, 100%

    {
        transform: none;
    }

    50% {
        transform: scale3d(1.1, 1.1, 1);
    }

    }

    @@keyframes fill {
        100%

    {
        box-shadow: inset 0px 0px 0px 50px #28a745;
    }

    }
</style>

<div class="container text-center mt-5">
    <div class="card shadow p-4 mx-auto" style="max-width: 600px;">
        <div class="card-body">

            <div class="checkmark-wrapper">
                <svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52">
                    <circle class="checkmark__circle" cx="26" cy="26" r="25" fill="none" />
                    <path class="checkmark__check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8" />
                </svg>
            </div>

            <h2 class="mb-3 fw-bold text-success">¡Compra Realizada!</h2>
            <p class="lead text-muted">Tus boletos han sido generados exitosamente.</p>

            <div class="alert alert-light border border-secondary border-dashed mt-4 text-start shadow-sm">
                <h4 class="text-primary fw-bold text-center mb-3">@ViewBag.Pelicula</h4>

                <div class="row">
                    <div class="col-6">
                        <small class="text-muted d-block fw-bold">Sala</small>
                        <span class="fs-6">@ViewBag.Sala</span>
                    </div>
                    <div class="col-6 text-end">
                        <small class="text-muted d-block fw-bold">Hora</small>
                        <span class="fs-6">@Convert.ToDateTime(ViewBag.Hora).ToString("hh:mm tt")</span>
                    </div>
                </div>

                <hr class="my-2" />

                <div class="row align-items-center">
                    <div class="col-7">
                        <small class="text-muted d-block fw-bold mb-1">Asientos</small>
                        @foreach (var boleto in Model)
                        {
                            <span class="badge bg-dark me-1 mb-1">@boleto.AsientoCodigo</span>
                        }
                    </div>
                    <div class="col-5 text-end">
                        <small class="text-muted d-block fw-bold">Total Pagado</small>
                        <span class="fs-4 text-success fw-bold">@Convert.ToDecimal(ViewBag.Total).ToString("C")</span>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <p class="text-muted small mb-2">Muestra este código en la entrada:</p>

                <div style="animation: fadeIn 2s;">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=@Model.First().CodigoQr"
                         alt="Cargando código QR..."
                         class="img-thumbnail"
                         style="min-height: 150px; min-width: 150px; background-color: #f8f9fa;" />
                </div>
            </div>

            <div class="mt-5">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-5 shadow-sm">
                    Volver a Cartelera
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes fadeIn {
        from

    {
        opacity: 0;
    }

    to {
        opacity: 1;
    }

    }
</style>