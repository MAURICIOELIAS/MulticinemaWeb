@model MulticinemaWeb.Models.Usuario
@{
    ViewData["Title"] = "Registrarse";
}

<style>
    body {
        background-color: #0a0e17;
        color: white;
        overflow-y: auto;
    }

    .glass-card {
        background: rgba(15, 20, 30, 0.85);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 0 40px rgba(0, 0, 0, 0.6);
        border-radius: 15px;
    }

    .form-control-modern {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: white !important;
    }

        .form-control-modern:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: #28a745;
            box-shadow: 0 0 10px rgba(40, 167, 69, 0.3);
            color: white;
        }

    label {
        font-size: 0.85rem;
        color: #adb5bd;
    }
</style>

<div class="d-flex justify-content-center align-items-center py-5 min-vh-100">
    <div class="card glass-card shadow" style="width: 500px; max-width: 95%;">
        <div class="card-body p-4">
            <h3 class="text-center mb-4 fw-bold text-white">Crear Cuenta</h3>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger text-center bg-danger bg-opacity-25 border-danger text-white">⚠️ @ViewBag.Error</div>
            }

            <form asp-action="Registrar" method="post">
                <div class="mb-3">
                    <label class="form-label">Nombre Completo</label>
                    <input asp-for="NombreCompleto" class="form-control form-control-modern" placeholder="Juan Pérez" required />
                    <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">DUI (Opcional)</label>
                        <input asp-for="Dui" id="inputDui" class="form-control form-control-modern" placeholder="00000000-0" />
                        <span asp-validation-for="Dui" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Teléfono</label>
                        <input asp-for="Telefono" class="form-control form-control-modern" placeholder="7000-0000" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Correo Electrónico <span class="text-danger">*</span></label>
                    <input asp-for="Correo" type="email" class="form-control form-control-modern" required />
                    <span asp-validation-for="Correo" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Contraseña <span class="text-danger">*</span></label>
                    <input type="password" name="passwordInput" class="form-control form-control-modern" placeholder="******" required />
                    <div class="form-text text-white-50" style="font-size: 0.75em;">Mínimo 6 caracteres, 1 número y 1 símbolo.</div>
                </div>

                <button type="submit" class="btn btn-success w-100 fw-bold shadow">Registrarse</button>
            </form>

            <div class="mt-3 text-center">
                <a asp-action="Login" class="text-decoration-none text-white-50 small">¿Ya tienes cuenta? <span class="text-warning">Inicia sesión</span></a>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('inputDui').addEventListener('input', function (e) {
        let valor = e.target.value.replace(/\D/g, '');
        if (valor.length > 9) valor = valor.slice(0, 9);
        if (valor.length > 8) valor = valor.slice(0, 8) + "-" + valor.slice(8);
        e.target.value = valor;
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}