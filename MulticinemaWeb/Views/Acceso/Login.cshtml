@{
    ViewData["Title"] = "Iniciar Sesión";
}

<style>
    body {
        background-color: #0a0e17;
        background-image: radial-gradient(circle at 50% 50%, rgba(13, 110, 253, 0.1) 0%, transparent 60%);
        color: white;
        height: 100vh;
        overflow-y: auto; /* IMPORTANTE: Permite scroll si la pantalla es pequeña */
    }

    .login-glass {
        background: rgba(15, 20, 30, 0.85);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 0 40px rgba(0, 0, 0, 0.6);
        border-radius: 15px;
    }

    .form-control-modern {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: white !important;
        border-radius: 8px;
    }

        .form-control-modern:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: #ffc107;
            box-shadow: 0 0 10px rgba(255, 193, 7, 0.2);
            color: white;
        }
</style>

<div class="d-flex justify-content-center align-items-center min-vh-100 py-5">
    <div class="card login-glass p-4" style="width: 400px; max-width: 90%;">
        <div class="text-center mb-4">
            <img src="/img/logo.png" alt="Logo Multicinema" style="max-height: 80px;" onerror="this.style.display='none'">
            <h3 class="fw-bold mt-2" style="color: #ffc107; text-shadow: 0 0 10px rgba(255,193,7,0.3);">MULTICINEMA</h3>
            <small class="text-muted">Bienvenido de nuevo</small>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center py-2 mb-3 bg-danger bg-opacity-25 border-danger text-white">@ViewBag.Error</div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label class="form-label text-white-50 small">Correo Electrónico</label>
                <input type="email" name="correo" class="form-control form-control-modern" placeholder="name@example.com" value="@ViewBag.CorreoGuardado" required />
            </div>
            <div class="mb-3">
                <label class="form-label text-white-50 small">Contraseña</label>
                <input type="password" name="password" class="form-control form-control-modern" placeholder="••••••••" required />
            </div>
            <div class="mb-4 form-check">
                <input type="checkbox" class="form-check-input bg-dark border-secondary" id="checkGuardar" name="guardarSesion" value="true">
                <label class="form-check-label small text-muted" for="checkGuardar">Recordar mi usuario</label>
            </div>
            <button type="submit" class="btn btn-primary w-100 fw-bold py-2 shadow-sm" style="background-color: #0d6efd;">INGRESAR</button>
        </form>

        <div class="d-flex align-items-center my-4">
            <hr class="flex-grow-1 border-secondary opacity-50">
            <span class="mx-2 text-muted small">o</span>
            <hr class="flex-grow-1 border-secondary opacity-50">
        </div>

        <a asp-action="IngresarComoInvitado" class="btn btn-outline-light w-100 mb-4 btn-sm py-2 opacity-75">
            👤 Continuar como Invitado
        </a>

        <div class="text-center">
            <small class="text-white-50">¿Nuevo aquí? <a asp-action="Registrar" class="text-warning text-decoration-none fw-bold">Crea tu cuenta</a></small>
        </div>
    </div>
</div>